# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in the values you received from the
# vacancy application form (/vacancy-application.html).
#
# The X-Access-Key and admin credentials are shown only ONCE by the server,
# so store them safely. NEVER commit the real .env file.
# ---------------------------------------------------------------------------

# Base URL of the application under test
BASE_URL=https://qa-a.recruitment.mediamarslab.com

# Access key issued for your application: "<identifier>.<secret>"
# Required on every /api/* request except POST /api/applications.
X_ACCESS_KEY=

# Administrator account issued together with the access key.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# HTTP Basic Auth credentials for GET /api/analytics/events
# (these are shared/fixed values provided in the assignment).
ANALYTICS_BASIC_USER=QA_USER
ANALYTICS_BASIC_PASSWORD=
